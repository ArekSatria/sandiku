# =========================
# SANDIKU Git Ignore
# =========================

# Environment variables
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Python virtual environments
venv/
env/
.venv/
backend/venv/
backend/env/
backend/.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.coverage.*
coverage.xml

# Local database
*.db
*.sqlite
*.sqlite3
backend/*.db
backend/*.sqlite
backend/*.sqlite3

# Node.js
node_modules/
frontend/node_modules/
dist/
frontend/dist/
dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build/cache
.cache/
.vite/
frontend/.vite/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temporary files
tmp/
temp/
*.tmp