# =========================
# SANDIKU Backend Environment
# =========================

# Database lokal untuk pengembangan
DATABASE_URL=sqlite:///./sandiku.db

# Ganti SECRET_KEY sebelum deployment
SECRET_KEY=ganti-dengan-random-string-yang-panjang-dan-sulit-ditebak

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS untuk frontend lokal
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin awal, digunakan oleh:
# python -m app.scripts.create_admin
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sandiku.local
ADMIN_PASSWORD=ArekSatria07!