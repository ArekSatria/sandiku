# =========================
# SANDIKU Backend Environment
# =========================

# Mode aplikasi: development atau production
APP_ENV=development
DEBUG=true

# Database lokal untuk pengembangan
DATABASE_URL=sqlite:///./sandiku.db

# Ganti SECRET_KEY sebelum deployment
SECRET_KEY=ganti-dengan-random-string-yang-panjang-dan-sulit-ditebak

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dokumentasi API
# Set false pada production jika Swagger UI ingin dinonaktifkan
ENABLE_DOCS=true

# CORS untuk frontend lokal
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security headers
SECURITY_HEADERS_ENABLED=true

# HSTS hanya aktifkan jika backend sudah berjalan melalui HTTPS
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000

# Rate limiting
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_PER_MINUTE=5
ANALYZE_RATE_LIMIT_PER_MINUTE=30

# Opsional: dipakai oleh script python -m app.scripts.create_admin
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sandiku.local
ADMIN_PASSWORD=ArekSatria071!